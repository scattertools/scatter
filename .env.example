# =============================================================================
# Scatter — environment template.
#   cp .env.example .env   and fill in the values below.
# `.env` is gitignored; never commit real secrets.
#
# Consumed by:
#   - docker-compose.yml          (coordinator env_file + web build args)
#   - apps/coordinator (validated in apps/coordinator/src/env.ts via zod)
#   - apps/web         (NEXT_PUBLIC_* read in apps/web/lib/env.ts, build-time)
# =============================================================================

# -----------------------------------------------------------------------------
# Coordinator — REQUIRED
# -----------------------------------------------------------------------------
# The ONLY required variable. Min 32 chars (zod-validated) — the app crashes on
# boot if missing/too short. Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-please-generate-with-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# Coordinator — server
# -----------------------------------------------------------------------------
# Port the coordinator listens on (default 4000).
PORT=4000
# Bind address (default 0.0.0.0 — required inside containers).
HOST=0.0.0.0
# Log level: fatal | error | warn | info | debug | trace (default info).
LOG_LEVEL=info

# SQLite database file (single file + WAL). In docker-compose this is overridden
# to /data/scatter.db, which is backed by the `coordinator-data` named volume so
# data persists across restarts. For non-Docker local dev: ./data/scatter.db
DATABASE_PATH=/data/scatter.db

# -----------------------------------------------------------------------------
# Coordinator — auth / sessions
# -----------------------------------------------------------------------------
# Magic-link lifetime in minutes (default 15).
MAGIC_LINK_TTL_MINUTES=15
# Session lifetime in days (default 30).
SESSION_TTL_DAYS=30

# -----------------------------------------------------------------------------
# Coordinator — CORS / URLs
# -----------------------------------------------------------------------------
# Public URL of the web app (used in magic-link emails). Default http://localhost:3000
WEB_BASE_URL=http://localhost:3000
# Comma-separated list of CORS-allowed browser origins (default http://localhost:3000).
# Add every origin the browser will use to call the API.
ALLOWED_ORIGINS=http://localhost:3000

# Trust reverse-proxy X-Forwarded-* headers so the real client IP is used for
# rate limiting (instead of the proxy's IP). Set this ONLY when the coordinator
# actually runs behind a trusted proxy / load balancer (e.g. the Caddy service
# in docker-compose), otherwise clients can spoof X-Forwarded-For.
#   false (default) | true (single upstream) | <N> hops | <csv of IPs/CIDRs>
TRUST_PROXY=false

# -----------------------------------------------------------------------------
# Coordinator — SMTP (OPTIONAL)
# If unset, magic links are logged to the coordinator console instead of emailed.
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-smtp-password
SMTP_FROM=Scatter <noreply@scatter.tools>

# -----------------------------------------------------------------------------
# Coordinator — credits & limits (OPTIONAL, sensible defaults shown)
# -----------------------------------------------------------------------------
# Credits granted to a new user (default 100).
INITIAL_CREDITS=100
# Max upload size for anonymous users in bytes (default 104857600 = 100 MB).
ANONYMOUS_MAX_FILE_BYTES=104857600
# Max upload size for free-tier users in bytes (default 1073741824 = 1 GB).
FREE_MAX_FILE_BYTES=1073741824
# Max single shard size in bytes (default 4194304 = 4 MB).
MAX_SHARD_BYTES=4194304
# Dev-only: allow one node to hold multiple shards of the same file.
# Keep false in production for real redundancy (default false).
ALLOW_SHARD_STACKING=false

# -----------------------------------------------------------------------------
# Web — Next.js (build-time, baked into the client bundle)
# These are read as docker-compose build args for the `web` service.
# -----------------------------------------------------------------------------
# Coordinator URL the BROWSER hits (default http://localhost:4000).
NEXT_PUBLIC_API_URL=http://localhost:4000
# Public URL of the web app itself (default http://localhost:3000).
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Production TLS proxy (docker-compose.prod.yml + Caddyfile) — OPTIONAL
# Only needed when running the HTTPS overlay:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
# Caddy obtains Let's Encrypt certs automatically for these (public) domains.
# When using the proxy, also set TRUST_PROXY=true above and point the URLs
# below + WEB_BASE_URL/ALLOWED_ORIGINS/NEXT_PUBLIC_* at the https:// domains.
# -----------------------------------------------------------------------------
# WEB_DOMAIN=scatter.tools
# API_DOMAIN=api.scatter.tools
# TLS_EMAIL=admin@scatter.tools
