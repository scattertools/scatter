{
  "name": "coordinator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --experimental-strip-types --env-file=.env --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types --no-warnings 'test/**/*.test.ts'"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/websocket": "^11.2.0",
    "@scatter/protocol": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "fastify": "^5.2.1",
    "jose": "^5.9.6",
    "nodemailer": "^6.9.16",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.0"
  }
}
