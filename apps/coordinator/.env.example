# Server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_PATH=./data/scatter.db

# Auth
JWT_SECRET=generate-with-openssl-rand-hex-32
MAGIC_LINK_TTL_MINUTES=15
SESSION_TTL_DAYS=30

# Links + CORS
WEB_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Email (magic links)
# Leave SMTP_* blank to log links to console instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Scatter <noreply@scatter.tools>

# Limits
ANONYMOUS_MAX_FILE_BYTES=104857600
FREE_MAX_FILE_BYTES=1073741824
MAX_SHARD_BYTES=4194304

# Starting credits for new users
INITIAL_CREDITS=100

# Sharding
ALLOW_SHARD_STACKING=true